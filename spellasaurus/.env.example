# ─────────────────────────────────────────────────────────────────────────────
# Spellasaurus — local environment config
# Never commit these files. Both are already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# 1) Flutter app (.env.json)
#    Used with: flutter run --dart-define-from-file=.env.json
#    Copy to .env.json and fill in your values:
#
#    {
#      "SUPABASE_URL": "https://your-project.supabase.co",
#      "SUPABASE_ANON_KEY": "your-anon-key-here"
#    }

# 2) Supabase Edge Functions (supabase/.env)
#    Used by: supabase functions serve  (local dev)
#    For production, set secrets with:
#      supabase secrets set OPENAI_API_KEY=sk-...
#      supabase secrets set SUPABASE_SERVICE_ROLE_KEY=eyJ...
#
#    supabase/.env contents:
#      SUPABASE_URL=https://your-project.supabase.co
#      SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
#      OPENAI_API_KEY=your-openai-api-key-here

# Where to find these values:
#   Supabase dashboard → Settings → API
#   SUPABASE_URL        = "Project URL"
#   SUPABASE_ANON_KEY   = "anon public" key
#   SUPABASE_SERVICE_ROLE_KEY = "service_role secret" key  ← keep this safe!
#   OpenAI              = https://platform.openai.com/api-keys
